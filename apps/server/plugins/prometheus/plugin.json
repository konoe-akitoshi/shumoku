{
  "id": "prometheus",
  "name": "Prometheus",
  "version": "0.1.0",
  "description": "Prometheus monitoring integration for metrics, hosts, and alerts",
  "capabilities": ["metrics", "hosts", "alerts"],
  "entry": "index.js",
  "configSchema": {
    "type": "object",
    "required": ["url", "preset"],
    "properties": {
      "url": { "type": "string", "title": "Prometheus URL" },
      "preset": {
        "type": "string",
        "title": "Metric Preset",
        "enum": ["snmp", "node_exporter", "custom"]
      },
      "basicAuth": {
        "type": "object",
        "title": "Basic Auth",
        "properties": {
          "username": { "type": "string" },
          "password": { "type": "string", "format": "password" }
        }
      },
      "hostLabel": { "type": "string", "title": "Host Label" },
      "jobFilter": { "type": "string", "title": "Job Filter" },
      "alertmanagerUrl": { "type": "string", "title": "Alertmanager URL" }
    }
  }
}
