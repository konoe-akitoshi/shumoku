{
  "id": "grafana",
  "name": "Grafana",
  "version": "0.1.0",
  "description": "Grafana integration for alerts via Alertmanager API or webhook",
  "capabilities": ["alerts"],
  "entry": "index.js",
  "configSchema": {
    "type": "object",
    "required": ["url", "token"],
    "properties": {
      "url": { "type": "string", "title": "Grafana URL" },
      "token": { "type": "string", "title": "API Token", "format": "password" },
      "useWebhook": { "type": "boolean", "title": "Use Webhook" },
      "webhookSecret": { "type": "string", "title": "Webhook Secret", "format": "password" }
    }
  }
}
