{
  "name": "@shumoku/docs",
  "version": "0.2.25",
  "private": true,
  "scripts": {
    "collect": "node scripts/collect-docs.mjs",
    "build": "node scripts/collect-docs.mjs && next build",
    "dev": "node scripts/collect-docs.mjs && next dev",
    "start": "next start",
    "typecheck": "node scripts/collect-docs.mjs && fumadocs-mdx && next typegen && tsc --noEmit",
    "postinstall": "node scripts/collect-docs.mjs && fumadocs-mdx",
    "lint": "biome check",
    "format": "biome check --write ."
  },
  "dependencies": {
    "@radix-ui/react-tooltip": "^1.2.8",
    "@shumoku/core": "workspace:*",
    "@shumoku/renderer-html": "workspace:*",
    "@shumoku/renderer-svg": "workspace:*",
    "clsx": "^2.1.1",
    "fumadocs-core": "16.10.7",
    "fumadocs-mdx": "15.0.13",
    "fumadocs-ui": "16.10.7",
    "lucide-react": "^1.23.0",
    "next": "16.2.10",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "shumoku": "workspace:*",
    "tailwind-merge": "^3.4.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "@shumoku/renderer": "workspace:*",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/mdx": "^2.0.13",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18"
  }
}
