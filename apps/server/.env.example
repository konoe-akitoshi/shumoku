# Shumoku Server - Compose environment
# Copy to `.env` (same directory as compose.yaml); `docker compose` reads it
# automatically. compose.yaml stays unedited — all knobs live here.
#
#   cp .env.example .env
#   docker compose up -d

# Image tag to run. Pin an exact version for production (recommended) so
# upgrades and rollbacks are deliberate. `latest` follows the newest stable
# release; `beta` follows the newest beta.
#   https://github.com/konoe-akitoshi/shumoku/pkgs/container/shumoku
SHUMOKU_VERSION=latest

# Host port to publish. The container always listens on 8080 internally;
# this only changes the host side (e.g. 80 for a plain HTTP deployment).
SHUMOKU_PORT=8080

# Seed the sample-network topology and stream mock metrics on first start
# (no Prometheus/Zabbix needed). Keep false for real deployments.
DEMO_MODE=false
