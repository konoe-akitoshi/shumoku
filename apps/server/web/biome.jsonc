{
  "root": false,
  "$schema": "../../../node_modules/@biomejs/biome/configuration_schema.json",
  "extends": ["../../../biome.jsonc"],
  "linter": {
    "rules": {
      "a11y": "off",
      "complexity": {
        "noImportantStyles": "off"
      }
    }
  },
  "files": {
    "includes": ["!**/.svelte-kit", "!**/build"]
  },
  "css": {
    "parser": {
      "tailwindDirectives": true,
      "cssModules": true
    }
  }
}
