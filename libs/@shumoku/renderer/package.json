{
  "name": "@shumoku/renderer",
  "version": "0.1.0",
  "description": "Interactive Svelte-based renderer for Shumoku network diagrams",
  "license": "AGPL-3.0-only",
  "author": "konoe-akitoshi",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/konoe-akitoshi/shumoku.git",
    "directory": "libs/@shumoku/renderer"
  },
  "type": "module",
  "svelte": "./src/index.ts",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "svelte": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./wc": {
      "types": "./dist/wc.svelte.d.ts",
      "default": "./dist/wc/wc.js"
    },
    "./components/ShumokuRenderer.svelte": {
      "svelte": "./src/components/ShumokuRenderer.svelte",
      "default": "./dist/components/ShumokuRenderer.svelte"
    },
    "./static": {
      "svelte": "./src/static.ts",
      "types": "./dist/static.d.ts",
      "default": "./dist/static.js"
    }
  },
  "files": [
    "dist/",
    "src/"
  ],
  "scripts": {
    "dev": "vite dev",
    "build": "svelte-package -i src && vite build --outDir dist/wc --emptyOutDir",
    "typecheck": "svelte-check --tsconfig ./tsconfig.json",
    "lint": "biome check .",
    "format": "biome check --write ."
  },
  "dependencies": {
    "@shumoku/core": "workspace:*",
    "d3-drag": "^3.0.0",
    "d3-selection": "^3.0.0",
    "d3-zoom": "^3.0.0",
    "wheel-gestures": "^2.2.48"
  },
  "devDependencies": {
    "@sveltejs/package": "^2.3.2",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@types/d3-drag": "^3.0.7",
    "@types/d3-selection": "^3.0.11",
    "@types/d3-zoom": "^3.0.8",
    "svelte": "^5.17.3",
    "svelte-check": "^4.1.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.10"
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  }
}
