{
  "name": "@shumoku/layout",
  "version": "0.1.0",
  "description": "Layout and routing engines for shumoku network topology visualization",
  "license": "AGPL-3.0-only",
  "author": "konoe-akitoshi",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/konoe-akitoshi/shumoku.git",
    "directory": "libs/@shumoku/layout"
  },
  "homepage": "https://shumoku.packof.me/",
  "bugs": {
    "url": "https://github.com/konoe-akitoshi/shumoku/issues"
  },
  "keywords": [
    "network",
    "topology",
    "layout",
    "routing",
    "graph"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./placement": {
      "types": "./dist/placement/index.d.ts",
      "import": "./dist/placement/index.js"
    },
    "./routing": {
      "types": "./dist/routing/index.d.ts",
      "import": "./dist/routing/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "lint": "biome check ."
  },
  "dependencies": {
    "@shumoku/core": "workspace:*",
    "elkjs": "^0.11.0"
  },
  "devDependencies": {
    "@types/node": "^25.0.7",
    "typescript": "^5.6.3",
    "vitest": "^4.0.17"
  },
  "publishConfig": {
    "access": "public"
  }
}
