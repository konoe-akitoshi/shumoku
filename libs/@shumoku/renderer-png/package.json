{
  "name": "@shumoku/renderer-png",
  "version": "0.2.25",
  "description": "PNG renderer for Shumoku network diagrams",
  "license": "AGPL-3.0-only",
  "author": "konoe-akitoshi",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/konoe-akitoshi/shumoku.git",
    "directory": "libs/@shumoku/renderer-png"
  },
  "type": "module",
  "main": "./dist/index.js",
